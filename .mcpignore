# CloakMCP internals — the protector must not pack itself.
# Source contains regex patterns, base62 alphabets, IP literals, and PEM
# headers that look like secrets but are detection logic.
cloakmcp/
tests/
examples/
docs/
api/
deploy/
.github/
assets/
base/
pyproject.toml
README.md
README*
